# LLM Provider: openai or anthropic
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=your-api-key-here
# Model settings (claude-haiku-4-5-20251001=빠름/저렴, claude-sonnet-4-6=균형, claude-opus-4-7=최고품질)
MODEL_NAME=claude-haiku-4-5-20251001
EMBEDDING_MODEL=local

# Server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# File upload settings
UPLOAD_DIR=/tmp/pcap_uploads
MAX_FILE_SIZE_MB=50

# RAG settings
FAISS_INDEX_DIR=rag/faiss_index
TOP_K_RESULTS=5
